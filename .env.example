# Environment Variables
OPENAI_API_KEY=your_openai_api_key_here
CLICKATELL_PHONE_NUMBER=your_business_phone_number
PORT=3001

# Mistral OCR — used to extract text from signed Letters of Engagement
# Get a key from https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_mistral_api_key_here
# Optional override — defaults to mistral-ocr-latest. Pin to a specific version
# (e.g. mistral-ocr-2025-09) if you need reproducible extraction across runs.
MISTRAL_OCR_MODEL=mistral-ocr-latest
