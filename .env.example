# =============================================================================
# TTT WhatsApp Tax Bot — Environment Variables
# =============================================================================
# Copy this to .env and fill in the values. Never commit .env to git.

# --- Azure / Dynamics 365 ---
DYNAMICS_URL=https://yourorg.crm4.dynamics.com/
DYNAMICS_TENANT_ID=
DYNAMICS_CLIENT_ID=
DYNAMICS_CLIENT_SECRET=

# --- Meta WhatsApp Cloud API ---
# Leave empty for DRY-RUN mode (bot works normally but doesn't send real WhatsApp messages).
# Fill in to enable real WhatsApp delivery.
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=
META_APP_SECRET=

# --- AI / LLM ---
OPENAI_API_KEY=

# --- Mistral OCR ---
# Used to extract text from signed Letters of Engagement.
# Get a key from https://console.mistral.ai/api-keys
MISTRAL_API_KEY=
MISTRAL_OCR_MODEL=mistral-ocr-latest

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Bot config (TTT-specific) ---
SIGNUP_URL=https://app.ttt-tax.co.za/signup

# --- Optional (legacy Clickatell) ---
CLICKATELL_API_KEY=
CLICKATELL_PHONE_NUMBER=

# --- Server ---
PORT=3001
